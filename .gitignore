# ---- Credentials ----
# js/config.js is generated at build time by scripts/generate-config.js from
# the SUPABASE_URL / SUPABASE_ANON_KEY Netlify environment variables.
# For local dev, copy js/config.example.js to js/config.js and fill in values,
# or run `SUPABASE_URL=... SUPABASE_ANON_KEY=... node scripts/generate-config.js`.
